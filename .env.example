# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
# 서버 제어(/askpj restart|stop) 권한자 — 쉼표 구분 Slack user ID (예: U01ABC,U02DEF)
WIKI_ADMIN_USERS=

# Confluence
CONFLUENCE_TOKEN=<base64 email:api-token>

# GitHub (github.enabled=true 시, public 레포는 선택)
GITHUB_TOKEN=ghp_...

# LLM (provider=ANTHROPIC 시)
ANTHROPIC_API_KEY=sk-ant-...

# Google (provider=GOOGLE 또는 rag.embeddingMode=GOOGLE_EMBEDDING 시)
GOOGLE_API_KEY=AIza...

# 코드 프리징 리마인더 (scripts/codefreeze) — 사용 시에만
CODEFREEZE_ICS_URL=https://calendar.google.com/calendar/ical/.../private-XXXX/basic.ics
CODEFREEZE_CHANNEL=C0XXXXXXXXX
CODEFREEZE_REPORT_USER_ID=U0XXXXXXXXX
